# Core server
PORT=3000

# Persistence driver
# Supported: json-file | sqlite
STORAGE_DRIVER=json-file
# Used when STORAGE_DRIVER=sqlite
STORAGE_SQLITE_PATH=data/storage/metadata.sqlite

# LLM runtime
# Supported selector aliases: ollama | llama-server | openai | gemini | gpt-plugin | codex
LLM_PROVIDER=ollama
LLM_TIMEOUT_MS=15000
LLM_PLANNING_TIMEOUT_MS=30000
LLM_MAX_RETRIES=2
LLM_STRICT_JSON=true
LLM_MAX_ITERATIONS=2
LLM_THINKING_BUDGET_ENABLED=false
LLM_THINKING_BUDGET=1024

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_PLANNING_MODEL=qwen3:8b
OLLAMA_VISION_MODEL=qwen3-vl:4b
VISION_TIMEOUT_MS=30000
VISION_MAX_RETRIES=1
HA_SNAPSHOT_DESCRIBE=true

# Main conversation runtime
# classic = legacy route -> planning chain
# windowed-agent = message-based window runtime with short-lived skill lease
MAIN_CONVERSATION_MODE=classic
CONVERSATION_WINDOW_TIMEOUT_SECONDS=180
CONVERSATION_WINDOW_MAX_TURNS=6
CONVERSATION_AGENT_MAX_STEPS=4

# Memory (global hybrid memory)
LLM_MEMORY_CONTEXT_ENABLED=true
MEMORY_COMPACT_EVERY_ROUNDS=4
MEMORY_COMPACT_MAX_BATCH_SIZE=8
MEMORY_SUMMARY_TOP_K=4
MEMORY_RAW_REF_LIMIT=8
MEMORY_RAW_RECORD_LIMIT=3

# llama-server
LLAMA_SERVER_BASE_URL=http://127.0.0.1:8080
LLAMA_SERVER_MODEL=qwen3-thinking
LLAMA_SERVER_PLANNING_MODEL=qwen3-thinking
LLAMA_SERVER_API_KEY=
LLAMA_SERVER_CHAT_TEMPLATE_KWARGS={"enable_thinking":true}
LLAMA_SERVER_PLANNING_CHAT_TEMPLATE_KWARGS={"enable_thinking":true,"thinking_budget":1024}

# OpenAI / ChatGPT API
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_PLANNING_MODEL=gpt-4.1-mini
OPENAI_CHAT_OPTIONS=
OPENAI_PLANNING_CHAT_OPTIONS=
OPENAI_FALLBACK_TO_CHATGPT_BRIDGE=true
OPENAI_FORCE_BRIDGE=false
# Optional local guardrails (avoid silent overrun)
OPENAI_QUOTA_RESET_DAY=1
OPENAI_MONTHLY_TOKEN_LIMIT=
OPENAI_MONTHLY_BUDGET_USD=
# Optional cost estimation (USD / 1M tokens)
OPENAI_COST_INPUT_PER_1M=
OPENAI_COST_OUTPUT_PER_1M=

# Gemini / Google GenAI API
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_PLANNING_MODEL=
GEMINI_CHAT_OPTIONS=
GEMINI_PLANNING_CHAT_OPTIONS=

# GPT Plugin (chatgpt-bridge as a unified LLM provider)
GPT_PLUGIN_MODEL=
GPT_PLUGIN_PLANNING_MODEL=
GPT_PLUGIN_TIMEOUT_MS=30000
GPT_PLUGIN_PLANNING_TIMEOUT_MS=30000

# Codex CLI (local codex exec provider)
LLM_CODEX_MODEL=
LLM_CODEX_PLANNING_MODEL=
LLM_CODEX_REASONING_EFFORT=
LLM_CODEX_PLANNING_REASONING_EFFORT=
# Optional: never | on-request | on-failure | untrusted
LLM_CODEX_APPROVAL_POLICY=never
# Optional: read-only | workspace-write | danger-full-access
LLM_CODEX_SANDBOX=read-only

# Market Analysis (equity + fund)
# /market explanation markdown -> image pipeline is strict:
# - Requires npm deps: satori, @resvg/resvg-js, remark
# - Missing dependency detection covers MODULE_NOT_FOUND / ESM ERR_MODULE_NOT_FOUND / "Cannot find package/module"
# - Offline deploy should preinstall: npm install satori @resvg/resvg-js remark
# - Missing deps / markdown generation failure / image render failure will throw MARKET_IMAGE_PIPELINE_FAILED
# - No pure-text fallback for explanation mode
# - Dynamic install/resolve targets project package root first (not arbitrary startup cwd)
# - Troubleshooting: npm ls satori @resvg/resvg-js remark
ENABLE_FUND_ANALYSIS=true
MARKET_ANALYSIS_LLM_ENABLED=true
MARKET_ANALYSIS_LLM_MODEL=
MARKET_ANALYSIS_FUND_LOCAL_MODEL=
# Timeout priority:
# MARKET_ANALYSIS_LLM_TIMEOUT_MS > provider profile config.timeoutMs > LLM_TIMEOUT_MS > 60000 (internal fallback)
# For codex provider, recommend >=60000 to avoid codex timeout after 15000ms.
MARKET_ANALYSIS_LLM_TIMEOUT_MS=60000
# fund.llmRetryMax is configured in Admin -> Market Analysis; larger values increase total LLM wait time linearly.
# Legacy compatibility when analysisEngine=gemini (prefer provider-id in admin)
MARKET_ANALYSIS_GEMINI_MODEL=gemini-2.0-flash
MARKET_ANALYSIS_GEMINI_TIMEOUT_MS=15000
SERPAPI_KEY=
SERPAPI_ENDPOINT=https://serpapi.com/search.json
QIANFAN_SEARCH_API_KEY=
QIANFAN_SEARCH_ENDPOINT=https://qianfan.baidubce.com/v2/ai_search/web_search
QIANFAN_SEARCH_SOURCE=baidu_search_v2
QIANFAN_SEARCH_EDITION=standard
QIANFAN_SEARCH_TOP_K=10
QIANFAN_SEARCH_RECENCY_FILTER=month
QIANFAN_SEARCH_SAFE_SEARCH=false
MARKET_ANALYSIS_NEWS_API=
MARKET_ANALYSIS_NEWS_CONTEXT=
FUND_ACCOUNT_RISK_PREFERENCE=balanced
FUND_ACCOUNT_HOLDING_HORIZON=medium_term

# Home Assistant
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=your_home_assistant_token
HA_ENTITY_REFRESH_MS=60000

# WeCom
WECOM_TOKEN=your_wecom_token
WECOM_CORP_ID=your_corp_id
WECOM_APP_SECRET=your_app_secret
WECOM_AGENT_ID=your_agent_id
WECOM_CONTEXT_LIMIT=1000
WECOM_AUDIO_DIR=data/wecom-audio
# Image responses (for example /market explanation) require bridge delivery.
# Direct /ingress/wecom callback channel only supports text reply.
WECOM_MEDIA_USE_BRIDGE=true

# Optional WeCom bridge
# Required for image replies and Admin menu publish when WeCom is behind IP allowlists.
WECOM_BRIDGE_URL=
WECOM_BRIDGE_TOKEN=

# Optional WeCom notify target
WECOM_NOTIFY_TO=
# Optional evolution notify target (higher priority than WECOM_NOTIFY_TO)
EVOLUTION_NOTIFY_TO=
HA_NOTIFY_TOKEN=

# STT
# Supported: fast-whisper | mock
STT_PROVIDER=fast-whisper
STT_FAST_WHISPER_AUTO_INSTALL=true
STT_FAST_WHISPER_PYTHON=python3
STT_FAST_WHISPER_SCRIPT=tools/fast-whisper-transcribe.py
STT_FAST_WHISPER_MODEL=small
STT_FAST_WHISPER_DEVICE=auto
STT_FAST_WHISPER_COMPUTE_TYPE=int8
STT_FAST_WHISPER_LANGUAGE=zh
STT_FAST_WHISPER_BEAM_SIZE=1
STT_FAST_WHISPER_VAD_FILTER=true
STT_FAST_WHISPER_TIMEOUT_MS=180000

# Scheduler / evolution
SCHEDULE_TICK_MS=10000
EVOLUTION_TICK_MS=30000
EVOLUTION_MAX_FIX_ATTEMPTS=2
EVOLUTION_MAX_RETRY_ATTEMPTS=6
EVOLUTION_RETRY_BASE_MS=600000
EVOLUTION_RETRY_MAX_MS=21600000
EVOLUTION_ENABLE_HARD_ROLLBACK=false
EVOLUTION_GIT_PUSH_REMOTE=
EVOLUTION_GIT_PUSH_BRANCH=
